# Required
GEMINI_API_KEY=your_google_gemini_api_key
# Required for direct Sora text-to-video generation
OPENAI_API_KEY=your_openai_api_key
# Required for Kling motion generation and fal-based music
FAL_KEY=your_fal_api_key

# Optional web server override for app.rb
HOST=0.0.0.0
PORT=8791
INTERNAL_APP_URL=http://127.0.0.1:3000
PUBLIC_APP_URL=https://your-public-app-url.example.com
SORA_STUDIO_PUBLIC_APP_URL=https://your-public-app-url.example.com
SORA_STUDIO_NOTIFY_EMAIL_TO=
SORA_STUDIO_EMAIL_NOTIFICATIONS=true
SORA_STUDIO_EMAIL_ATTACHMENT_MAX_MB=20
SORA_STUDIO_RENDER_MODELS=seedance2
# Optional: burn accurate Whisper captions from generated video audio
SORA_STUDIO_CAPTIONS=true
SORA_STUDIO_CAPTION_TRANSCRIPTION_MODEL=whisper-1
SORA_STUDIO_CAPTION_TRANSCRIPTION_TIMEOUT_MS=120000
SORA_STUDIO_CAPTION_AUDIO_MAX_MB=24
SORA_STUDIO_CAPTIONS_SCRIPT_FALLBACK=false

# Gmail Workspace inbound/outbound email automation
GMAIL_WORKSPACE_USER=neha@hypergro.ai
GMAIL_PROCESSED_LABEL=kotak-processed
GMAIL_INBOX_QUERY=in:inbox is:unread -label:kotak-processed

# Optional model overrides
GEMINI_LOGIC_MODEL=gemini-3.1-pro-preview
GEMINI_LOGIC_FALLBACK_MODELS=gemini-2.5-pro,gemini-3-flash-preview
GEMINI_QC_MODEL=gemini-3.1-pro-preview
GEMINI_QC_FALLBACK_MODELS=gemini-2.5-pro,gemini-3-flash-preview
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
GEMINI_VEO_MODEL=veo-3.1-generate-preview
GEMINI_VEO_TEXT_MODEL=veo-3.1-generate-001
GEMINI_SCRIPT_MODEL=gemini-3-flash-preview
GEMINI_SCRIPT_FALLBACK_MODELS=gemini-2.5-pro,gemini-3.1-pro-preview
GEMINI_SORA_MODEL=gemini-2.5-pro
GEMINI_SORA_HTTP_TIMEOUT_MS=120000
# Sora Studio script/prompt generation via Anthropic on Google Vertex AI
ANTHROPIC_VERTEX_PROJECT_ID=your_gcp_project_id
ANTHROPIC_VERTEX_LOCATION=global
ANTHROPIC_VERTEX_FALLBACK_LOCATIONS=us-east5,us-central1
ANTHROPIC_VERTEX_MODEL=claude-sonnet-4-6
ANTHROPIC_VERTEX_FALLBACK_MODELS=claude-sonnet-4-5@20250929,claude-3-7-sonnet@20250219,claude-3-5-sonnet-v2@20241022,claude-3-5-sonnet@20240620
ANTHROPIC_VERTEX_MAX_TOKENS=2048
ANTHROPIC_VERTEX_HTTP_TIMEOUT_MS=120000
# Optional auth paths for Anthropic on Vertex:
# 1) ADC (recommended): set GOOGLE_APPLICATION_CREDENTIALS to your service-account json path
# 2) Inline credentials json:
ANTHROPIC_VERTEX_SERVICE_ACCOUNT_JSON=
# 3) Pre-minted OAuth token:
ANTHROPIC_VERTEX_ACCESS_TOKEN=
# Sora Studio script/prompt generation via Anthropic through fal any-llm
ANTHROPIC_FAL_MODEL=anthropic/claude-sonnet-4.5
ANTHROPIC_FAL_FALLBACK_MODELS=anthropic/claude-3.7-sonnet,anthropic/claude-3.5-sonnet,anthropic/claude-haiku-4.5
FAL_VEO_TEXT_MODEL=fal-ai/veo3.1
FAL_VEO_IMAGE_MODEL=fal-ai/veo3.1/image-to-video
VEO_MAX_CONCURRENCY=2
SORA_I2V_FAL_VEO_POLL_INTERVAL_MS=2500
SORA_I2V_FAL_VEO_POLL_MAX_ATTEMPTS=720
SORA_I2V_FAL_VEO_SUBSCRIBE_TIMEOUT_MS=1805000
SORA_MODEL=sora-2-pro
ENABLE_SORA_PROMPT_WRITER=true
SORA_PROMPT_WRITER_MODEL=gemini-3-pro-preview
SORA_PROMPT_WRITER_FALLBACK_MODEL=gemini-2.5-pro
SORA_PROMPT_WRITER_REASONING_EFFORT=high
SORA_PROMPT_WRITER_THINKING_BUDGET=2048
SORA_PROMPT_WRITER_MAX_OUTPUT_TOKENS=1200
FAL_SORA_TEXT_MODEL=fal-ai/sora-2/text-to-video/pro
FAL_IMAGE_MODEL=fal-ai/gpt-image-1.5
FAL_SORA_RESOLUTION=1080p
FAL_TOPAZ_VIDEO_MODEL=fal-ai/topaz/upscale/video
# off | sora_only | all
TOPAZ_UPSCALE_MODE=sora_only
TOPAZ_UPSCALE_FACTOR=2
TOPAZ_MODEL=Proteus
TOPAZ_RECOVER_DETAIL=0.35
TOPAZ_COMPRESSION=0.12
TOPAZ_NOISE=0.10
TOPAZ_HALO=0.08
TOPAZ_GRAIN=0.03
TOPAZ_H264_OUTPUT=true
KLING_TEXT_MODEL=fal-ai/kling-video/v3/pro/text-to-video
WHISPER_CLI_PATH=/absolute/path/to/whisper
WHISPER_MODEL=base
WHISPER_MODEL_DIR=/absolute/path/to/whisper-model-cache
ALLOW_LYRIA_LIVE_FALLBACK=false

# Optional retry tuning
GENAI_MAX_ATTEMPTS=5
GENAI_RETRY_BASE_MS=1800
GENAI_HTTP_TIMEOUT_MS=180000
VEO_CELEBRITY_FILTER_REGENERATE_ATTEMPTS=3
SORA_MAX_ATTEMPTS=5
SORA_RETRY_BASE_MS=1800
SORA_POLL_INTERVAL_MS=10000
SORA_POLL_MAX_ATTEMPTS=60
FAL_SORA_POLL_INTERVAL_MS=2500
FAL_SORA_SUBSCRIBE_TIMEOUT_MS=1200000
FAL_SORA_DOWNLOAD_ATTEMPTS=3
FAL_SORA_DOWNLOAD_RETRY_DELAY_MS=1500
FAL_SORA_DOWNLOAD_TIMEOUT_MS=45000
FAL_TOPAZ_POLL_INTERVAL_MS=2500
FAL_TOPAZ_POLL_MAX_ATTEMPTS=240
FAL_TOPAZ_DOWNLOAD_TIMEOUT_MS=120000
GEMINI_SCRIPT_MAX_ATTEMPTS=5
GEMINI_SCRIPT_RETRY_BASE_MS=1200
GEMINI_SCRIPT_HTTP_TIMEOUT_MS=120000
KLING_MAX_ATTEMPTS=5
KLING_RETRY_BASE_MS=1800
KLING_POLL_INTERVAL_MS=2500

# Optional Python override used by /api/jobs/import-excel for XLSX parsing via openpyxl
EXCEL_PARSER_PYTHON_BIN=python3

# Hypergro sales deck app
GEMINI_DECK_MODEL=gemini-2.5-pro
GEMINI_DECK_FALLBACK_MODELS=gemini-3.1-pro-preview,gemini-2.5-flash
GEMINI_DECK_IMAGE_MODEL=imagen-4.0-generate-001
GEMINI_DECK_HTTP_TIMEOUT_MS=120000
# Option A: paste the full Google Workspace service-account JSON as one env value
GOOGLE_SERVICE_ACCOUNT_JSON=
# Option B: provide these fields separately
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Gmail Workspace note:
# - enable domain-wide delegation on the service account
# - authorize Gmail scopes for the workspace domain
# - the delegated user should match GMAIL_WORKSPACE_USER
# Optional: move new presentations into a specific Drive folder
GOOGLE_SLIDES_PARENT_FOLDER_ID=

# Optional final end slate stitching
END_SLATE_VIDEO_PATH=/absolute/path/to/end-slate.mp4
# Optional product-specific overrides
END_SLATE_AIR_PLUS_PATH=/absolute/path/to/air-plus-end-slate.mp4
END_SLATE_AIR_PLUS_INLINE_CTA_CARD_PATH=/absolute/path/to/air-plus-inline-cta-card.png
END_SLATE_AIR_PLUS_INLINE_CTA_BUTTON_PATH=/absolute/path/to/air-plus-inline-cta-button.png
END_SLATE_CASHBACK_PATH=/absolute/path/to/cashback-end-slate.mp4
# Freeze hold in seconds added to end of rendered outputs (final + adapts)
END_FREEZE_LAST_FRAME_SECONDS=0.5
# Optional legacy alias (used only if END_FREEZE_LAST_FRAME_SECONDS is not set)
HARD_CUT_TO_BLACK_SECONDS=0.5
# Optional extra hold before appending the end slate
PRE_END_SLATE_HOLD_SECONDS=0.5
FINAL_EXPORT_PRESET=slow
FINAL_EXPORT_CRF=14
FINAL_EXPORT_MAXRATE=12M
FINAL_EXPORT_BUFSIZE=24M
FINAL_EXPORT_AUDIO_BITRATE=256k

# Optional background score mix on final video
# `auto` (default): prefer fal Lyria 2, otherwise Lyria Live, then local file fallback
# `lyria`: generate score via Lyria only (fal Lyria 2 first, otherwise Lyria Live)
# `file`: use local file only
BACKGROUND_SCORE_SOURCE=auto
# fal Lyria 2 model
FAL_LYRIA_MODEL=fal-ai/lyria2
# Gemini Developer API / Lyria Live fallback model
LYRIA_MODEL=models/lyria-realtime-exp
BACKGROUND_SCORE_PATH=/absolute/path/to/background-score.mp3
# Optional product-specific overrides
BACKGROUND_SCORE_AIR_PLUS_PATH=/absolute/path/to/air-plus-background-score.mp3
BACKGROUND_SCORE_CASHBACK_PATH=/absolute/path/to/cashback-background-score.mp3
# Mix level is intentionally capped low in pipeline (recommended <= 0.22)
BACKGROUND_SCORE_VOLUME=0.10
# Fade duration in seconds for BGM in/out
BACKGROUND_SCORE_FADE_SECONDS=0.45
# End fade duration in seconds. Keep >= 0.35 to avoid abrupt cutoff at final frame.
BACKGROUND_SCORE_END_FADE_SECONDS=0.45
